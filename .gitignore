# Python
__pycache__/
*.pyc

# OS
.DS_Store
Thumbs.db

# Node / project-local Supabase CLI
node_modules/

# Supabase local CLI state (transient)
supabase/.temp/
supabase/.branches/

# Ad-hoc backups — git is the backup (repository-eos-review §9 retirement)
backup/

# Workstation generated logs & raw command captures (transient — scripts regenerate them).
# The curated workstation (scripts, manifest.md, reports/*.md) IS committed; see WORKSTATION.md.
.workstation/reports/*.txt
.workstation/reports/*.log
.workstation/reports/mcp/
.workstation/reports/tools/*.txt

# Local secrets (MCP tokens etc.) — never commit. .mcp.json itself is committed (no secrets in it).
.env
.env.local

# Machine-local Claude settings + their timestamped backups (personal, not shared)
.claude/settings.local.json
.claude/settings.local.backup-*.json
.claude/settings.json
